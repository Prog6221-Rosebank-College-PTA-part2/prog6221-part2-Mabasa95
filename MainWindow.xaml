<Window x:Class="Part_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Part_2"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot &amp; Assistant" Height="600" Width="900"
        Background="#1E1E24">

    <Window.Resources>
        <!-- Text style-->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!--Button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D81B60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AD1457"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Textbox style-->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D37"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#D81B60"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--Tab style -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252530"/>
            <Setter Property="Foreground" Value="#A0A0A5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="4,4,0,0" Margin="2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D81B60"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#353545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Welcome Screen -->
        <Grid x:Name="WelcomeGrid">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/Logo.jpeg" Width="500" Height="250" Margin="15"/>
                <Button Content="Start" Width="200" Height="45" Click="Start_Click"/>
            </StackPanel>
        </Grid>

        <!-- Name input screen -->
        <Grid x:Name="NameGrid" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Enter your name" FontSize="24" FontWeight="SemiBold" Margin="15" HorizontalAlignment="Center"/>
                <TextBox x:Name="NameTextBox" Width="300" Height="45" Margin="15"/>
                <TextBlock x:Name="ErrorText" Foreground="Red" Margin="5" TextAlignment="Center"/>
                <Button Content="Submit" Width="300" Height="45" Click="Submit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Main interface -->
        <TabControl x:Name="MainTabControl" Background="#15151C" BorderThickness="0" Margin="10" Visibility="Collapsed" SelectionChanged="MainTabControl_SelectionChanged">

            <!-- AI Chatbot tab -->
            <TabItem Header="🤖 AI Chatbot">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="LogoText" Grid.Row="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,10">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFF" Offset="0"/>
                                <GradientStop Color="#00FF88" Offset="0.5"/>
                                <GradientStop Color="#0080FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <!--Chat area-->
                    <TextBox x:Name="ChatListBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" FontFamily="Consolas" Background="#1A1A24" BorderBrush="#2D2D37" Padding="10"/>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!--Message input -->
                        <TextBox x:Name="InputTextBox" Grid.Column="0" Height="45" Margin="0,0,10,0"/>
                        <Button Content="Send" Grid.Column="1" Width="100" Height="45" Click="Send_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!--Task Assistant tab -->
            <TabItem Header="📋 Task Assistant">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Task Form -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Create New Task" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#D81B60"/>

                        <TextBlock Text="Task Title:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                        <TextBox x:Name="TaskTitleTextBox" Height="35" Margin="0,0,0,10"/>

                        <TextBlock Text="Description:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                        <TextBox x:Name="TaskDescTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" VerticalContentAlignment="Top"/>

                        <TextBlock Text="Set Reminder (Optional):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                        <DatePicker x:Name="TaskDatePicker" Height="35" Margin="0,0,0,15" Background="#2D2D37" Foreground="Black"/>

                        <Button Content="Add Task" Height="40" Click="AddTask_Click"/>
                    </StackPanel>

                    <!--Task List -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Your Cybersecurity Tasks" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <ListView x:Name="TaskListView" Grid.Row="1" Background="#1A1A24" Foreground="White" BorderBrush="#2D2D37">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#00FF88"/>
                                        <TextBlock Text="{Binding Description}" FontSize="14" Foreground="#D0D0D5" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ReminderDate, StringFormat='Reminder: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" Foreground="#8888FF" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="Mark Completed" Width="150" Height="40" Margin="0,0,10,0" Click="CompleteTask_Click"/>
                            <Button Content="Delete Task" Width="120" Height="40" Background="#900C3F" Click="DeleteTask_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!--Cyber Quiz tab -->
            <TabItem Header="🎮 Cyber Quiz">
                <Grid Margin="15" MaxWidth="600" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Cybersecurity Awareness Quiz" FontSize="20" FontWeight="Bold" Foreground="#D81B60" HorizontalAlignment="Center" Margin="0,10,0,20"/>

                    <!--Quiz start screen -->
                    <StackPanel x:Name="QuizStartPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Test your online safety awareness. Can you score 10/10?" TextAlignment="Center" FontSize="16" Margin="0,0,0,20" TextWrapping="Wrap"/>
                        <Button Content="Start Quiz" Width="200" Height="45" Click="StartQuiz_Click"/>
                    </StackPanel>

                    <!-- Question screen-->
                    <Grid x:Name="QuizQuestionPanel" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Question Counter and Text -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock x:Name="QuizCounterText" Text="Question 1 of 10" FontSize="12" Foreground="#8888FF"/>
                            <TextBlock x:Name="QuestionTextBlock" Text="Question Text?" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Answer options -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <RadioButton x:Name="OptARadioButton" Content="Option A" Foreground="White" FontSize="14" Margin="0,5"/>
                            <RadioButton x:Name="OptBRadioButton" Content="Option B" Foreground="White" FontSize="14" Margin="0,5"/>
                            <RadioButton x:Name="OptCRadioButton" Content="Option C" Foreground="White" FontSize="14" Margin="0,5"/>
                            <RadioButton x:Name="OptDRadioButton" Content="Option D" Foreground="White" FontSize="14" Margin="0,5"/>
                        </StackPanel>

                        <!-- Quiz buttons and Feedback -->
                        <StackPanel Grid.Row="2" Margin="0,15,0,0">
                            <TextBlock x:Name="QuizFeedbackText" Text="Correct / Incorrect Explanation" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="Collapsed"/>
                            <Button x:Name="SubmitAnswerButton" Content="Submit Answer" Height="40" Click="SubmitAnswer_Click"/>
                            <Button x:Name="NextQuestionButton" Content="Next Question" Height="40" Click="NextQuestion_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Final Score Screen -->
                    <StackPanel x:Name="QuizScorePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="Quiz Complete!" FontSize="22" FontWeight="Bold" Foreground="#00FF88" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="QuizFinalScoreText" Text="Your Score: 8/10" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="QuizConclusionText" Text="Great job! You're a cybersecurity pro!" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <Button Content="Play Again" Width="180" Height="40" Click="PlayAgain_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!--Activity Log list -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Recent Activity Log" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <ListBox x:Name="LogListBox" Grid.Row="1" Background="#1A1A24" Foreground="White" BorderBrush="#2D2D37" FontSize="13" FontFamily="Consolas" Padding="10"/>

                    <!-- View more log entries-->
                    <Button Grid.Row="2" Content="Show More Logs" Width="180" Height="40" Margin="0,15,0,0" HorizontalAlignment="Center" Click="ShowMoreLogs_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>